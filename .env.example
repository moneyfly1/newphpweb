APP_DEBUG=true
APP_TRACE=false

# 数据库配置（默认 SQLite，0.5G VPS 推荐）
DB_DRIVER=sqlite
DB_SQLITE_PATH=runtime/cboard.sqlite

# 如需 MySQL，改为以下配置：
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=cboard
# DB_USER=root
# DB_PASS=your_mysql_password
# DB_PREFIX=

# 站点配置
CB_APP_NAME=CBoard
CB_BASE_URL=http://127.0.0.1:8000

# 码支付配置（必填）
MZF_PID=
MZF_KEY=
MZF_API_URL=
MZF_SUBMIT_URL=

# GitHub 备份（可选）
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_REPO=
